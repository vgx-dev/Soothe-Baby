{
  "builds": [
    { "src": "website/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": { "X-Content-Type-Options": "nosniff" },
      "continue": true
    },
    { "src": "/(.+\\.[a-zA-Z0-9]+)$", "dest": "/website/$1" },
    { "src": "/(.*)", "dest": "/website/index.html" }
  ]
}
